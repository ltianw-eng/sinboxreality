{
 "log": {"level": "info"},
 "inbounds": [{
 "type": "vless",
 "listen": "0.0.0.0",
 "listen_port": 1443,
 "users": [{"uuid": "${UUID}", "flow": ""}],
 "tls": {
 "enabled": true,
 "server_name": "www.microsoft.com",
 "reality": {
 "enabled": true,
 "handshake": {"server": "www.microsoft.com", "server_port": 443},
 "private_key": "${PRIVATE_KEY}",
 "short_id": ["${SHORT_ID}"]
 }
 }
 }],
 "outbounds": [{"type": "direct"}]
}
